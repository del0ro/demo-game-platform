## Telegram bot
# Токен бота из @BotFather.
BOT_TOKEN=

# Telegram user id администраторов через запятую.
# Пример: 123456789,987654321
ADMIN_USER_IDS=

# Необязательные каналы для логов / админских уведомлений.
GAMES_CHANNEL_ID=
WALLETS_CHANNEL_ID=
ADMIN_CHANNEL_ID=

## Значения по умолчанию для новых пользователей
DEFAULT_BALANCE=0
DEFAULT_BET_AMOUNT=0.1

## Database
# PostgreSQL DSN для SQLAlchemy async engine.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/demo

## Demo payment provider
# Для demo можно оставить пустым, если провайдер не используется.
CRYPTOPAY_TOKEN=
CRYPTOPAY_TESTNET=true

## Application
DEBUG=false
LOG_LEVEL=INFO
LOG_DIR=logs
SHUTDOWN_TIMEOUT_SECONDS=15
THROTTLE_WINDOW_SECONDS=10
THROTTLE_LIMIT_PER_USER=15
USER_ACTION_LOCK_TTL_SECONDS=30
